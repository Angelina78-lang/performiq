{
  "info": {
    "name": "PerformIQ — Employee Performance Analytics API",
    "description": "Complete API collection for the PerformIQ MERN application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('authToken', jsonData.token);",
                  "  pm.environment.set('userId', jsonData.user._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@company.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('authToken', jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@company.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "👥 Employees",
      "item": [
        {
          "name": "Create Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('employeeId', jsonData.employee._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aarav Sharma\",\n  \"email\": \"aarav.sharma@company.com\",\n  \"department\": \"Development\",\n  \"skills\": [\"Node.js\", \"React\", \"MongoDB\"],\n  \"performanceScore\": 92,\n  \"experience\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            }
          }
        },
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            }
          }
        },
        {
          "name": "Search Employees",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/employees/search?department=Development&minScore=70&skill=React&name=Aarav",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "search"],
              "query": [
                {
                  "key": "department",
                  "value": "Development"
                },
                {
                  "key": "minScore",
                  "value": "70"
                },
                {
                  "key": "skill",
                  "value": "React"
                },
                {
                  "key": "name",
                  "value": "Aarav"
                }
              ]
            }
          }
        },
        {
          "name": "Get Employee by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            }
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aarav Sharma Updated\",\n  \"performanceScore\": 95,\n  \"skills\": [\"Node.js\", \"React\", \"MongoDB\", \"Docker\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            }
          }
        },
        {
          "name": "Update Performance Score",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"performanceScore\": 98\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}/score",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}", "score"]
            }
          }
        },
        {
          "name": "Get Stats Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/employees/stats/summary",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "stats", "summary"]
            }
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "🤖 AI Recommendations",
      "item": [
        {
          "name": "Recommend for Single Employee (by ID)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"{{employeeId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "recommend"]
            }
          }
        },
        {
          "name": "Recommend for Ad-hoc Employee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee\": {\n    \"name\": \"Priya Mehta\",\n    \"email\": \"priya@company.com\",\n    \"department\": \"AI/ML\",\n    \"skills\": [\"Python\", \"ML\", \"SQL\"],\n    \"performanceScore\": 88,\n    \"experience\": 4\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "recommend"]
            }
          }
        },
        {
          "name": "Rank Multiple Employees",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeIds\": [\"id1\", \"id2\", \"id3\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "recommend"]
