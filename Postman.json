          }
        },
        {
          "name": "Rank All Employees",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"all\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "recommend"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "employeeId",
      "value": "",
